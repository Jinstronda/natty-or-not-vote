# Netlify redirects for Single Page Application (SPA) routing
# This ensures that direct URL access to any route works correctly

# Static files should be served directly (not redirected to index.html)
/sitemap*.xml    /sitemap*.xml    200
/sitemaps/*      /sitemaps/:splat 200
/robots.txt      /robots.txt      200

# Redirect all other routes to index.html for client-side routing
/*    /index.html   200 